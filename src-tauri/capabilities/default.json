{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "notification",
    "notification-overlay-*"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "core:window:allow-close"
  ]
}
